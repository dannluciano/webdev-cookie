{% extends "layout.njk" %}

{% block content %}
  <article>
    <header>
      <h1>{{ title }}</h1>
    </header>
    <p>{{ message }}</p>
    {% if actions and actions.length %}
      <div class="grid">
        {% for action in actions %}
          <a
            href="{{ action.href }}"
            role="button"
            {% if action.secondary %}class="secondary"{% endif %}
          >
            {{ action.label }}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </article>
{% endblock %}
